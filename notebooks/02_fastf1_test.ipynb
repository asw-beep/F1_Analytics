    "import fastf1\n",
    "\n",
    "fastf1.Cache.enable_cache('../data/cache')\n",
    "\n",
    "session = fastf1.get_session(2023, 'Bahrain', 'R')\n",
    "session.load()\n",
    "\n",
    "results = session.results\n",
    "print(results[['FullName', 'TeamName', 'Position']])"
   ]
